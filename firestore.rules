rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: config
    // Document: global
    // Fields: vaultAddress (string), updatedAt (timestamp)
    //
    // Collection: networks
    // Fields: chainId (number), name (string), rpcUrl (string), isActive (bool)
    //
    // Collection: tokens
    // Fields: address (string), symbol (string), decimals (number), chainId (number)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /config/global {
      allow read, write: if true;
    }

    match /networks/{networkId} {
      allow read, write: if true;
    }

    match /tokens/{tokenId} {
      allow read, write: if true;
    }
  }
}
